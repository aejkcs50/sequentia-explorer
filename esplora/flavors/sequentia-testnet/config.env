#!/bin/bash

# SEQUENTIA testnet (chain=test) explorer flavor.
# Sequentia is an Elements fork (so IS_ELEMENTS=1 enables asset/issuance views),
# with a Proof-of-Stake BLS committee and Bitcoin (testnet4) anchoring surfaced
# by the patched electrs + esplora views.

export SITE_TITLE='Sequentia Testnet Explorer'
export HOME_TITLE='Sequentia Testnet Explorer'

# The chain=test policy ("bitcoin") asset — the native asset of the testnet.
export NATIVE_ASSET_ID=c8eccacf0953e1931cd31e434d8319101cc36e6c38b0e2104d8687552fae3e40
export NATIVE_ASSET_LABEL=tSEQ
export NATIVE_ASSET_NAME="Sequentia Testnet"

export IS_ELEMENTS=1
# Enables the Assets list view (esplora gates it on ASSET_MAP_URL) and provides
# friendly metadata for assets in tx/asset views. Sourced at runtime from the
# Sequentia Asset Registry (served at /registry on this origin) so labels are
# verified and centrally maintained, instead of the previously hardcoded
# _data/assets.minimal.json. The registry's /index.minimal.json uses the same
# {id:[domain,ticker,name,precision]} shape, so this is a drop-in.
export ASSET_MAP_URL=${ASSET_MAP_URL:-'/registry/index.minimal.json'}

export MENU_ACTIVE='Sequentia Testnet'
# Network switcher: toggle between Sequentia (this chain) and its Bitcoin
# testnet4 parent. Both dev-servers cross-link via the same MENU_ITEMS map.
export MENU_ITEMS=${MENU_ITEMS:-'{"Sequentia Testnet":"http://127.0.0.1:5001/","Bitcoin Testnet4":"http://127.0.0.1:5002/"}'}
# A block's Bitcoin anchor links to OUR own testnet4 explorer (the :5002
# instance), not mempool.space. The loopback host is rewritten to the page's
# host at click time (rebaseHost), so it works over Tailscale too.
export PARENT_CHAIN_EXPLORER_BLOCK=${PARENT_CHAIN_EXPLORER_BLOCK:-'http://127.0.0.1:5002/block/{hash}'}
# Footer links: the github icon -> the Sequentia-Esplora source repo; the brand
# mark -> sequentia.io (the project site, next to it).
export FOOTER_LINKS=${FOOTER_LINKS:-'{"img/github_blue.png":"https://github.com/aejkcs50/sequentia-explorer","img/icons/concatena-labs.png":"https://sequentia.io"}'}
export BASE_HREF=${BASE_HREF:-'/'}

# Reuse Liquid's asset-table styling, plus Sequentia branding/row styling.
export CUSTOM_CSS="$CUSTOM_CSS flavors/liquid/extras.css flavors/sequentia-testnet/extras.css"
